# Copy this file to `config/.env` before starting the app or running tests.

# HTTP service port for local reverse proxy or direct access.
HTTP_PORT=8080

# HTTPS service port for levels that require direct TLS access.
HTTPS_PORT=8443

# Dedicated HTTP/2 service port for protocol-specific levels.
HTTP2_PORT=9443

# Public origin allowed by the app CORS logic and used by tests.
APP_ORIGIN=https://localhost:8443

# Absolute path to the TLS private key file.
TLS_KEY_PATH=/absolute/path/to/tls/key.pem

# Absolute path to the TLS certificate file.
TLS_CERT_PATH=/absolute/path/to/tls/cert.pem
